# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# Logs / temp
*.log
tmp/

# Test harness deps + generated artifacts
test/node_modules/
test/*.png
test/**/*.png
test/screenshots/
# Playwright tests also drop bare-filename screenshots at the repo root
*.png
!assets/*.png
!images/*.png
# ...but web/public/ is SHIPPED static content, never a screenshot dump. Anything the
# site serves (banner.png for link previews, favicons, doc screenshots) must be tracked
# or it 404s in production.
!web/public/**/*.png
_docs/index.full.backup.html
.vercel
